global:
  scrape_interval: 15s

scrape_configs:
 
  - job_name: 'PR_metrics_scrape'

    static_configs:
      - targets: ['{{ exporter_host }}:{{ exporter_port }}']

  - job_name: 'Node_exporter'

    static_configs:
      - targets:
        - '172.16.111.42:9100'
        - '172.16.102.188:9100'
        - '172.16.111.107:9100'
