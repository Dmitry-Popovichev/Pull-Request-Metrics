global:
  scrape_interval: 15s

scrape_configs:
 
  - job_name: 'PR_metrics_scrape'

    static_configs:
      - targets: ['{{ exporter_host }}:{{ exporter_port }}']

  - job_name: 'Node_exporter'

    static_configs:
      - targets:
        - '{{ exporter_host }}:9100'
        - '{{ prometheus_host }}:9100'
        - '{{ grafana_host }}:9100'
